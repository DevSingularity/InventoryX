# ===============================
# Server Configuration
# ===============================
PORT=5000
NODE_ENV=development

# ===============================
# Database
# ===============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=invictus
DB_USER=postgres
DB_PASSWORD=postgres
# Optional one-line alternative:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invictus
# Set true only if your postgres requires SSL
DB_SSL=false

# ===============================
# Authentication / Security
# ===============================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
# Set false to disable auto-creation of demo login accounts on startup
ENABLE_DEMO_CREDENTIALS=true
# Password used when creating employees via admin API without explicit password
EMPLOYEE_DEFAULT_PASSWORD=employee123

# ===============================
# CORS
# ===============================
CLIENT_URL=http://localhost:5173

# ===============================
# Optionals
# ===============================
# COOKIE_SECRET=your_cookie_secret
# REFRESH_TOKEN_SECRET=your_refresh_secret
